{
  "name": "nestjs-training-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo para trilhas práticas de NestJS com Zod, Jest, TAP, GraphQL Supergraph e Bruno.",
  "workspaces": [
    "apps/*/*",
    "packages/*",
    "packages/*/*"
  ],
  "scripts": {
    "list:trails": "node tools/validate-repo/list-trails.js",
    "trail:info": "node tools/validate-repo/show-trail-info.js",
    "check:repo": "node tools/validate-repo/check-repo-structure.js",
    "check:templates": "node tools/validate-repo/check-templates.js",
    "generate:trail": "node tools/create-trail/create-trail.js",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "test": "npm run test --workspaces --if-present",
    "check": "npm run check:repo && npm run lint && npm run build && npm test"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.16",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "^7.2.2",
    "tap": "^21.6.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-fastify": "^11.1.16",
    "@nestjs/testing": "^11.1.16"
  }
}
